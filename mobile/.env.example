# Monaco Notepad Mobile - environment template
#
# 使い方:
#   1. このファイルを `.env.local` にコピー (`.env.local` は git 管理対象外)
#   2. Google Cloud Console → monaco-notepad プロジェクト → クライアント で
#      iOS / Android 用 OAuth クライアント ID を発行し、下記に貼り付ける
#
# EAS Build で使う場合は `eas secret:create` で同名のシークレットを登録する。
# 例: eas secret:create --scope project --name GOOGLE_OAUTH_IOS_CLIENT_ID --value "xxxxx.apps.googleusercontent.com"

GOOGLE_OAUTH_IOS_CLIENT_ID=REPLACE_WITH_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_ANDROID_CLIENT_ID=REPLACE_WITH_ANDROID_CLIENT_ID.apps.googleusercontent.com

# Web クライアントは通常不要。Expo dev client で auth.expo.io を経由する場合のみ設定。
GOOGLE_OAUTH_WEB_CLIENT_ID=
