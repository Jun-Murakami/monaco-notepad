{
  "name": "monaco-notepad-mobile",
  "version": "1.5.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "scripts": {
    "start": "expo start",
    "prebuild": "node ../scripts/sync-version.mjs && expo prebuild",
    "preandroid": "node ../scripts/sync-version.mjs",
    "android": "expo run:android",
    "preios": "node ../scripts/sync-version.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.1.2",
    "@react-native-community/netinfo": "11.5.2",
    "expo": "~55.0.16",
    "expo-auth-session": "~55.0.15",
    "expo-background-fetch": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-file-system": "~55.0.16",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "i18next": "^26.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.83.6",
    "react-native-code-highlighter": "^1.3.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
